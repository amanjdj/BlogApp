<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head.ejs') %>
    <title><%= blog.title %></title>

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <!-- Google Fonts -->

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <style>
      body {
        font-family: "Inter", sans-serif;
        background: #f8f5f1;
        color: #222;
      }

      .playfair {
        font-family: "Playfair Display", serif;
      }

      .hero-image {
        height: 500px;
        object-fit: cover;
        border-radius: 25px;
      }

      .category {
        color: #9c7b52;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-size: 0.85rem;
        font-weight: 600;
      }

      .article-content p {
        color: #555;
        line-height: 1.9;
        margin-bottom: 1.5rem;
        font-size: 1.05rem;
      }

      .custom-card {
        border: none;
        border-radius: 20px;
        overflow: hidden;
        transition: 0.3s;
      }

      .custom-card:hover {
        transform: translateY(-6px);
      }

      .custom-card img {
        height: 220px;
        object-fit: cover;
      }

      footer {
        background: #1f1f1f;
      }
    </style>
  </head>
  <body>
    <%- include('./partials/nav.ejs') %>
    <!-- <div class="container mt-4">
      <h1><%= blog.title %></h1>
      <img
        src="/<%= blog.coverImageURL  %>"
        width="700px"
        alt="BLOG COVER IMAGE"
      />
      <pre class="mt-3"><%= blog.body %></pre>
    </div>
    <div class="container mt-4">
      <img src="<%= blog.createdBy.profileImageURL %>" width="50px" />
      <%= blog.createdBy.fullName %>
    </div> -->

    <!-- Blog Details -->

    <section class="py-5">
      <div class="container">
        <div class="row justify-content-center">
          <div class="col-lg-10">
            <!-- Category -->

            <p class="category mb-3">Technology</p>

            <!-- Title -->

            <h1 class="playfair fw-bold display-3 mb-4"><%= blog.title %></h1>

            <!-- Author -->

            <div class="d-flex align-items-center gap-3 mb-5">
              <img
                src="<%= blog.createdBy.profileImageURL %>"
                class="rounded-circle"
                alt="author"
              />

              <div>
                <h6 class="mb-0 fw-bold"><%= blog.createdBy.fullName %></h6>

                <small class="text-secondary">
                  Published on <%= blog.createdAt %>
                </small>
              </div>
            </div>

            <!-- Hero Image -->

            <img
              src="/<%= blog.coverImageURL %>"
              class="img-fluid hero-image w-100 mb-5"
              alt="blog"
            />

            <!-- Content -->

            <div class="article-content">
              <pre><%= blog.body %></pre>

              <blockquote
                class="border-start border-4 border-dark ps-4 py-2 my-5"
              >
                <h4 class="playfair fst-italic"><%= `"${blog.blogQuote}"` %></h4>
              </blockquote>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- Comments Section -->

 <!-- COMMENTS SECTION -->

<section class="py-5">

  <div class="container">

    <div class="row justify-content-center">

      <div class="col-lg-8">

        <!-- Title -->

        <div class="mb-5">

          <h2 class="playfair fw-bold display-6">
            Comments
          </h2>

          <p class="text-secondary">
            Join the discussion and share your thoughts.
          </p>

        </div>

        <!-- Add Comment -->

        <% if (locals.user) { %>
          <div class="card border-0 shadow-sm rounded-4 mb-5">

          <div class="card-body p-4">

    
              <form action="/blog/comment/<%= blog._id %>" method="post">


              <div class="mb-4">

                <label class="form-label fw-semibold" for="comment">
                  Comment
                </label>

                <textarea
                  rows="5"
                  id="comment"
                  name="comment"
                  class="form-control rounded-4"
                  placeholder="Write your comment..."
                  required
                ></textarea>

              </div>

              <button class="btn btn-dark px-4 py-2 rounded-pill">
                Post Comment
              </button>

            </form>
            

           

          </div>

        </div>
        <% } %>


       

        <!-- Comments Wrapper -->
     

        <div id="commentsContainer">

          <!-- Visible Comments -->

          <% comments.slice(0,2).forEach(comment => { %>
           
              <div class="card border-0 shadow-sm rounded-4 mb-4">

            <div class="card-body p-4">

              <div class="d-flex align-items-center mb-3">
                  
                <img
                  src="<%= comment.createdBy.profileImageURL %>"
                  class="rounded-circle me-3"
                  alt=""
                  width="70px"
                >

                <div>

                  <h6 class="mb-0 fw-bold">
                    <%= comment.createdBy.fullName %>
                  </h6>

                  <small class="text-secondary">
                    <%= comment.createdAt
                    
                    %>
                  </small>

                </div>

              </div>

              <p class="text-secondary mb-0">
                <%= comment.content %>
              </p>

            </div>

          </div>
          <% }) %>

          

          <!-- Hidden Comments -->

          
          <div id="moreComments" class="d-none">
               <% comments.slice(2).forEach(comment => { %>

            <div class="card border-0 shadow-sm rounded-4 mb-4">

              <div class="card-body p-4">

                <div class="d-flex align-items-center mb-3">

                  <img
                    src="<%= comment.createdBy.profileImageURL %>"
                    class="rounded-circle me-3"
                    alt=""
                    width="70px"
                  >

                  <div>

                    <h6 class="mb-0 fw-bold">
                      <%= comment.createdBy.fullName %>
                    </h6>

                    <small class="text-secondary">
                      <%= comment.createdAt %>
                    </small>

                  </div>

                </div>

                <p class="text-secondary mb-0">
                  <%= comment.content %>
                </p>

              </div>

            </div>


            <% }) %>
          </div>

         

        </div>

        <!-- Show More Button -->

        <div class="text-center mt-4">

          <button
            id="toggleCommentsBtn"
            class="btn btn-outline-dark rounded-pill px-4 py-2"
          >
            Show All Comments
          </button>

        </div>

      </div>

    </div>

  </div>

</section>

<!-- SCRIPT -->





    <!-- Related Blogs -->

    <section class="pb-5">
      <div class="container">
        <div class="text-center mb-5">
          <h2 class="playfair fw-bold display-5">Related Articles</h2>
        </div>

        <div class="row g-4">
      
          
          <% blogs.filter(bl=>bl._id.toString()!==blog._id.toString()).slice(0,3).forEach(bl => { %>
           <div class="col-md-6 col-lg-4">
            <div class="card shadow-sm custom-card h-100">
              <img
                src="/<%= bl.coverImageURL %>"
                class="card-img-top"
                alt=""
              />

              <div class="card-body p-4">
                <p class="category mb-2"><%= bl.category %></p>

                <h4 class="playfair fw-bold mb-3">
                  <%= bl.title %>
                </h4>

                <a href="<%=bl._id  %>" class="text-dark fw-semibold text-decoration-none">
                  Read More →
                </a>
              </div>
            </div>
          </div>
          <% }) %>

      

  
        </div>
      </div>
    </section>

    <!-- Footer -->

    <footer class="text-white py-4">
      <div class="container text-center">
        <p class="mb-0">© 2026 LuxeBlog — Crafted with elegance.</p>
      </div>
    </footer>

    <!-- Bootstrap JS -->


<%- include('./partials/scripts.ejs')%>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>

    <script>

  const toggleBtn = document.getElementById("toggleCommentsBtn");
  const moreComments = document.getElementById("moreComments");

  let expanded = false;

  toggleBtn.addEventListener("click", () => {

    expanded = !expanded;

    if(expanded){

      moreComments.classList.remove("d-none");
      toggleBtn.innerText = "Show Less";

    }else{

      moreComments.classList.add("d-none");
      toggleBtn.innerText = "Show All Comments";

    }

  });

</script>
  
</body>
</html>
