<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head.ejs') %>
    <title>HomePage</title>

    <style>
      body {
        font-family: "Inter", sans-serif;
        background: #f8f5f1;
        color: #222;
      }

      .playfair {
        font-family: "Playfair Display", serif;
      }

      .hero {
        min-height: 90vh;
      }

      .hero-title {
        font-size: 4rem;
        line-height: 1.2;
      }

      .custom-btn {
        background: #1f1f1f;
        color: white;
        border-radius: 50px;
        padding: 12px 28px;
        transition: 0.3s;
      }

      .custom-btn:hover {
        background: #9c7b52;
        color: white;
        transform: translateY(-2px);
      }

      .blog-card {
        border: none;
        border-radius: 20px;
        overflow: hidden;
        transition: 0.3s;
      }

      .blog-card:hover {
        transform: translateY(-8px);
      }

      .blog-card img {
        height: 240px;
        object-fit: cover;
      }

      .category {
        color: #9c7b52;
        font-size: 0.8rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        font-weight: 600;
      }

      footer {
        background: #1f1f1f;
      }

      @media (max-width: 768px) {
        .hero-title {
          font-size: 2.6rem;
        }
      }
    </style>
  </head>
  <body>
    <%- include('./partials/nav.ejs') %>

    <!-- <div class="container mt-3 row row-cols-4">
<% blogs.forEach(blog => { %>
  <div class="col">

    <div class="card  " style="width: 18rem;">
      <img src="<%= blog.coverImageURL %>" class="card-img-top" alt="..." >
      <div class="card-body">
        <h5 class="card-title"><%= blog.title %></h5>
        <a href="/blog/<%= blog._id %>" class="btn btn-primary">VIEW</a>
      </div>
      
    </div>
  </div>
<% }) %>

    </div> -->

    <section class="hero d-flex align-items-center">
      <div class="container">
        <div class="row justify-content-center text-center">
          <div class="col-lg-8">
            <p class="text-uppercase fw-semibold text-secondary mb-3">
              Modern • Elegant • Minimal
            </p>

            <h1 class="hero-title playfair fw-bold mb-4">
              Thoughts, Stories <br />
              & Creative Ideas
            </h1>

            <p class="lead text-secondary mb-5">
              A premium blog design built using Bootstrap with classy
              typography, clean spacing, and modern aesthetics.
            </p>

            <a href="blog/allBlogs" class="btn custom-btn">
              Explore Articles
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Blog Section -->

    <section class="py-5">
      <div class="container">
        <div class="text-center mb-5">
          <h2 class="playfair fw-bold display-5">Latest Articles</h2>
        </div>

        <div class="row g-4">
          <!-- Card 1 -->

          <% blogs.slice(0,3).forEach(blog => { %>
              <div class="col-md-6 col-lg-4">
            <div class="card shadow-sm blog-card h-100">
              <img
                src="/<%= blog.coverImageURL %>"
                class="card-img-top"
                alt="blog"
              />

              <div class="card-body p-4">
                <p class="category mb-2"><%= blog.category %></p>

                <h3 class="playfair fw-bold fs-3 mb-3">
                  <%= blog.title %>
                </h3>

                <p class="text-secondary mb-4">
                 <%= blog.body.slice(0,100) %>
                </p>

                <a href="blog/<%= blog._id %>" class="text-dark fw-semibold text-decoration-none">
                  Read More →
                </a>
              </div>
            </div>
          </div>
          <% }) %>
       

          <!-- Card 2 -->

          <!-- Card 3 -->
        </div>
      </div>
    </section>

    <!-- Footer -->

    <footer class="text-white py-4 mt-5">
      <div class="container text-center">
        <p class="mb-0">© 2026 AMAN BLOGIFY.</p>
      </div>
    </footer>

    <%- include('./partials/scripts.ejs')%>
  </body>
</html>
